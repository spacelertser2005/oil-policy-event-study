# Data files (too large for git, keep locally)
data/raw/*.csv
data/raw/*.xls
data/raw/*.xlsx
data/raw/*.parquet
data/raw/*.pkl
data/processed/*.csv
data/processed/*.xlsx
data/processed/*.parquet
data/processed/*.pkl

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep

# Secrets / credentials
.env
.env.*
*.env
secrets.*
credentials.*
*.pem
*.key
.pgpass
pgpass.conf
wrds_credentials*
.wrdsauth
config.local.*

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# IDE / tooling
.vscode/
.idea/
.claude/
*.swp

# Output (regenerable)
output/tables/*.csv
output/tables/*.tex
output/figures/*.png
output/figures/*.pdf
!output/tables/.gitkeep
!output/figures/.gitkeep

# Logs
*.log
